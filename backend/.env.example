# Copia este archivo como .env y rellena los valores
# NUNCA commitees el archivo .env real al repositorio
GROQ_API_KEY=Your_api_key_here

# Usa una clave larga, aleatoria y privada (minimo 32 caracteres)
JWT_SECRET_KEY=change_this_for_a_long_random_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Clave para usar la tool de tavily
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

